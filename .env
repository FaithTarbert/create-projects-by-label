# Cycode API credentials (OAuth2 client credentials)
CYCODE_CLIENT_ID=YOUR_CLIENT_ID
CYCODE_CLIENT_SECRET=YOUR_CLIENT-SECRET

# Base URL (default: https://api.cycode.com)
CYCODE_BASE_URL=https://api.cycode.com

# Business impact to assign to newly created projects (Low, Medium, High)
DEFAULT_BUSINESS_IMPACT=Medium
